{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://armut-germany-start-production.up.railway.app",
        "EXPO_PUBLIC_WEB_URL": "https://armut-germany-start-web-islekerens-projects.vercel.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://armut-germany-start-production.up.railway.app",
        "EXPO_PUBLIC_WEB_URL": "https://armut-germany-start-web-islekerens-projects.vercel.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
