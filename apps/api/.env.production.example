# Production / hosted database example
# Keep the same DATABASE_URL variable name, but point it to your managed Postgres instance.
# Example formats:
# - Render Postgres: postgresql://user:password@host:5432/dbname
# - Neon/Supabase often require SSL: postgresql://user:password@host:5432/dbname?sslmode=require

DATABASE_URL="postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE_NAME?sslmode=require"

JWT_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

PORT=4000
NODE_ENV="production"

# Set this to your Vercel production domain. You can add preview domains too.
CORS_ORIGINS="https://your-web-domain.vercel.app,https://your-preview-domain-*.vercel.app"

# Optional services
REDIS_URL=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@armut.de"
S3_ENDPOINT=""
S3_BUCKET=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""
MEILISEARCH_HOST=""
MEILISEARCH_API_KEY=""
GOOGLE_MAPS_API_KEY=""
